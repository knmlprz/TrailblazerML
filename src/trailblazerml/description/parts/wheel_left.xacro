<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:include filename="../macros/colors.xacro" />
    <xacro:include filename="../macros/inertial_macros.xacro" />
    <xacro:property name="wheel_color_name" value="blue" />
    <xacro:property name="wheel_color_rgb" value="${xacro:call('material_color', wheel_color_name)}" />

    <xacro:macro name="wheel_left" params="name mass">
        <link name="${name}">
            <visual>
                <origin xyz="0.6 0.07 -0.17" rpy="${pi/2} ${pi/2} ${pi/2}"/>
                <geometry>
                    <mesh filename="file://$(find trailblazerml)/models/rover_stl/wheel_left.stl" scale="0.001 0.001 0.001"/>
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="file://$(find trailblazerml)/models/rover_stl/wheel_left.stl" scale="1 1 1"/>
                </geometry>
                <material name="blue"/>
            </collision>
            <xacro:inertial_cylinder mass="${mass}" length="${wheel_length}" radius="${wheel_radius}">
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </xacro:inertial_cylinder>
        </link>

        <!-- Fix the joint definition with proper quotes -->
        <joint name="${name}_joint" type="continuous">
            <parent link="rover_body"/>
            <child link="${name}"/>
            <origin xyz="0 0 0"/>
        </joint>
    </xacro:macro>
</robot>
